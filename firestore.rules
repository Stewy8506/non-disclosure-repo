rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 💬 Global Anonymous Chat Rules
    match /chat_messages/{messageId} {
      // Anyone can read and post to the global chat feed
      allow read, write: if true;
    }
    
    // ✉️ Guestbook Rules
    match /guestbook/{messageId} {
      // Anyone visiting the site can read and sign the guestbook
      allow read, write: if true;
    }
    
    // ✉️ Contact Form Submission Rules
    match /contact_messages/{messageId} {
      // Anyone visiting the site can submit a contact message
      allow create: if true;
      
      // STRICT LOCKDOWN: Nobody can read, edit, or delete messages from the frontend client.
      // You will read these directly from your secure Firebase Console backend.
      allow read, update, delete: if false;
    }

    // 🛠️ Skills Rules
    match /skills/{document=**} {
      // Allow read access to anyone (public portfolio)
      allow read: if true;
      // Allow write access (e.g. for development / admin panel updates)
      allow write: if true; 
    }

    // 🚀 Projects Rules
    match /projects/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // ⚙️ Configuration Rules (e.g. employment status settings)
    match /config/{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
